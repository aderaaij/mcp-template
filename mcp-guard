#!/usr/bin/env bash
# Safety net for the supergateway child-process leak (see CLAUDE.md, 2026-07-14).
#
# The patched gateway at ~/.local/share/mcp-common reaps idle sessions, so this
# should normally do nothing. It exists because the leak previously drove units
# into their 512M MemoryMax and got them OOM-killed mid-handshake, which surfaces
# to the user as "could not attach to MCP server <x>" in Claude Desktop.
#
# Restarts any MCP unit whose cgroup memory exceeds THRESHOLD_PCT of its cap,
# i.e. catches a leak *before* the OOM killer does. Silent when healthy.
#
# Usage: mcp-guard [--dry-run]
set -uo pipefail

THRESHOLD_PCT="${MCP_GUARD_THRESHOLD_PCT:-75}"
DRY_RUN=0
[ "${1:-}" = "--dry-run" ] && DRY_RUN=1

APP_SLICE="/sys/fs/cgroup/user.slice/user-1000.slice/user@1000.service/app.slice"
acted=0

for unit in $(systemctl --user list-units --type=service --state=active --no-legend --plain 2>/dev/null \
              | awk '{print $1}' | grep -E '^[a-z0-9-]+-mcp\.service$'); do
  cg="$APP_SLICE/$unit"
  cur=$(cat "$cg/memory.current" 2>/dev/null) || continue
  max=$(cat "$cg/memory.max" 2>/dev/null) || continue
  [ "$max" = "max" ] && continue   # no cap set, nothing to measure against
  [ -z "$cur" ] || [ -z "$max" ] && continue

  pct=$(( cur * 100 / max ))
  procs=$(wc -l < "$cg/cgroup.procs" 2>/dev/null || echo 0)

  if [ "$pct" -ge "$THRESHOLD_PCT" ]; then
    acted=1
    msg="$unit at ${pct}% of MemoryMax ($(numfmt --to=iec "$cur")/$(numfmt --to=iec "$max"), ${procs} procs)"
    if [ "$DRY_RUN" -eq 1 ]; then
      echo "WOULD RESTART: $msg"
    else
      echo "RESTARTING: $msg"
      logger -t mcp-guard "restarting $unit: ${pct}% of MemoryMax, ${procs} procs (leak safety net)"
      systemctl --user restart "$unit"
    fi
  fi
done

[ "$acted" -eq 0 ] && exit 0
exit 0
